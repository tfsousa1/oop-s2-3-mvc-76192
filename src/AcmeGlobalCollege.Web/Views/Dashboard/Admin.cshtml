@{
    ViewData["Title"] = "Admin Dashboard";
}

<section class="agc-hero agc-hero-small">
    <div class="container">
        <span class="agc-eyebrow">Administrator Area</span>
        <h1 class="agc-title">Admin Dashboard</h1>
        <p class="agc-subtitle">
            Manage academic structures and institutional records across all branches.
        </p>
    </div>
</section>

<section class="agc-section">
    <div class="container">
        <div class="row g-4">
            <div class="col-md-6 col-xl-3">
                <div class="agc-card h-100">
                    <h5>Branches</h5>
                    <p>Manage branch locations and institutional structure.</p>
                </div>
            </div>

            <div class="col-md-6 col-xl-3">
                <div class="agc-card h-100">
                    <h5>Courses</h5>
                    <p>Manage courses, modules and academic delivery structure.</p>
                </div>
            </div>

            <div class="col-md-6 col-xl-3">
                <div class="agc-card h-100">
                    <h5>Enrolments</h5>
                    <p>Track student enrolments and course assignment records.</p>
                </div>
            </div>

            <div class="col-md-6 col-xl-3">
                <div class="agc-card h-100">
                    <h5>Results Release</h5>
                    <p>Control assessment visibility and administrative result workflows.</p>
                </div>
            </div>
        </div>
    </div>
</section>