@model AcmeGlobalCollege.Web.ViewModels.AdminDashboardViewModel

@{
    ViewData["Title"] = "Admin Dashboard";
}

<section class="agc-hero agc-hero-small">
    <div class="container">
        <span class="agc-eyebrow">Administrator Area</span>
        <h1 class="agc-title">Admin Dashboard</h1>
        <p class="agc-subtitle">
            Manage academic structures and institutional records across all branches.
        </p>
    </div>
</section>

<section class="agc-section">
    <div class="container">
        <div class="row g-4">
            <div class="col-md-6 col-xl-2">
                <a asp-controller="Branches" asp-action="Index" class="agc-card-link">
                    <div class="agc-card h-100">
                        <h5>Branches</h5>
                        <p class="agc-stat">@Model.TotalBranches</p>
                    </div>
                </a>
            </div>

            <div class="col-md-6 col-xl-2">
                <a asp-controller="Courses" asp-action="Index" class="agc-card-link">
                    <div class="agc-card h-100">
                        <h5>Courses</h5>
                        <p class="agc-stat">@Model.TotalCourses</p>
                    </div>
                </a>
            </div>

            <div class="col-md-6 col-xl-2">
                <div class="agc-card h-100">
                    <h5>Faculty</h5>
                    <p class="agc-stat">@Model.TotalFaculty</p>
                </div>
            </div>

            <div class="col-md-6 col-xl-3">
                <a asp-controller="Students" asp-action="Index" class="agc-card-link">
                    <div class="agc-card h-100">
                        <h5>Students</h5>
                        <p class="agc-stat">@Model.TotalStudents</p>
                    </div>
                </a>
            </div>

            <div class="col-md-6 col-xl-3">
                <a asp-controller="Enrolments" asp-action="Index" class="agc-card-link">
                    <div class="agc-card h-100">
                        <h5>Enrolments</h5>
                        <p class="agc-stat">@Model.TotalEnrolments</p>
                    </div>
                </a>
            </div>
        </div>
    </div>
</section>

<section class="agc-section pt-0">
    <div class="container">
        <div class="row g-4">
            <div class="col-lg-5">
                <div class="agc-card h-100">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h4 class="mb-0">Branches</h4>
                        <a asp-controller="Branches" asp-action="Index" class="btn btn-sm agc-btn-outline">View all</a>
                    </div>

                    @if (Model.Branches.Any())
                    {
                        <div class="table-responsive">
                            <table class="table agc-table">
                                <thead>
                                    <tr>
                                        <th>Name</th>
                                        <th>Address</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var branch in Model.Branches)
                                    {
                                        <tr>
                                            <td>@branch.Name</td>
                                            <td>@branch.Address</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted mb-0">No branches found.</p>
                    }
                </div>
            </div>

            <div class="col-lg-7">
                <div class="agc-card h-100">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h4 class="mb-0">Courses</h4>
                        <a asp-controller="Courses" asp-action="Index" class="btn btn-sm agc-btn-outline">View all</a>
                    </div>

                    @if (Model.Courses.Any())
                    {
                        <div class="table-responsive">
                            <table class="table agc-table">
                                <thead>
                                    <tr>
                                        <th>Course</th>
                                        <th>Branch</th>
                                        <th>Start</th>
                                        <th>End</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var course in Model.Courses)
                                    {
                                        <tr>
                                            <td>@course.Name</td>
                                            <td>@course.Branch?.Name</td>
                                            <td>@course.StartDate.ToString("dd/MM/yyyy")</td>
                                            <td>@course.EndDate.ToString("dd/MM/yyyy")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted mb-0">No courses found.</p>
                    }
                </div>
            </div>
        </div>
    </div>
</section>