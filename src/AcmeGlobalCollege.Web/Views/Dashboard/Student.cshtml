@model AcmeGlobalCollege.Web.ViewModels.StudentDashboardViewModel

@{
    ViewData["Title"] = "Student Dashboard";
}

<div class="mb-4">
    <div class="text-muted small">Student Area</div>
    <h1 class="display-5 fw-bold">Student Dashboard</h1>
    <p class="lead mb-0">View your profile information and your current enrolments.</p>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-header">
        <h2 class="h5 mb-0">My Profile</h2>
    </div>
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Student Number</dt>
            <dd class="col-sm-9">@Model.Student.StudentNumber</dd>

            <dt class="col-sm-3">Full Name</dt>
            <dd class="col-sm-9">@Model.Student.FullName</dd>

            <dt class="col-sm-3">Email</dt>
            <dd class="col-sm-9">@Model.Student.Email</dd>

            <dt class="col-sm-3">Phone</dt>
            <dd class="col-sm-9">@Model.Student.Phone</dd>

            <dt class="col-sm-3">Address</dt>
            <dd class="col-sm-9">@Model.Student.Address</dd>

            <dt class="col-sm-3">Date of Birth</dt>
            <dd class="col-sm-9">@Model.Student.DateOfBirth.ToString("dd/MM/yyyy")</dd>
        </dl>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-header">
        <h2 class="h5 mb-0">My Enrolments</h2>
    </div>
    <div class="card-body">
        @if (Model.Enrolments.Any())
        {
            <div class="table-responsive">
                <table class="table table-striped align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Course</th>
                            <th>Branch</th>
                            <th>Enrolment Date</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var enrolment in Model.Enrolments)
                    {
                        <tr>
                            <td>@enrolment.Course?.Name</td>
                            <td>@enrolment.Course?.Branch?.Name</td>
                            <td>@enrolment.EnrolDate.ToString("dd/MM/yyyy")</td>
                            <td>@enrolment.Status</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="alert alert-info mb-0">
                You do not currently have any enrolments.
            </div>
        }
    </div>
</div>