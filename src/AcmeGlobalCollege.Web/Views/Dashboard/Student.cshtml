@model AcmeGlobalCollege.Web.ViewModels.StudentDashboardViewModel

@{
    ViewData["Title"] = "Student Dashboard";
    var totalEnrolments = Model.Enrolments.Count;
    var activeEnrolments = Model.Enrolments.Count(e => e.Status == "Active");
}

<div class="mb-4">
    <div class="text-muted small">Student Area</div>
    <h1 class="display-5 fw-bold">Student Dashboard</h1>
    <p class="lead mb-0">View your profile information and your current enrolments.</p>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small">Student Number</div>
                <div class="fs-4 fw-bold">@Model.Student.StudentNumber</div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small">Total Enrolments</div>
                <div class="fs-4 fw-bold">@totalEnrolments</div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small">Active Enrolments</div>
                <div class="fs-4 fw-bold">@activeEnrolments</div>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-header">
        <h2 class="h5 mb-0">My Profile</h2>
    </div>
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Student Number</dt>
            <dd class="col-sm-9">@Model.Student.StudentNumber</dd>

            <dt class="col-sm-3">Full Name</dt>
            <dd class="col-sm-9">@Model.Student.FullName</dd>

            <dt class="col-sm-3">Email</dt>
            <dd class="col-sm-9">@Model.Student.Email</dd>

            <dt class="col-sm-3">Phone</dt>
            <dd class="col-sm-9">@Model.Student.Phone</dd>

            <dt class="col-sm-3">Address</dt>
            <dd class="col-sm-9">@Model.Student.Address</dd>

            <dt class="col-sm-3">Date of Birth</dt>
            <dd class="col-sm-9">@Model.Student.DateOfBirth.ToString("dd/MM/yyyy")</dd>
        </dl>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-header">
        <h2 class="h5 mb-0">My Enrolments</h2>
    </div>
    <div class="card-body">
        @if (Model.Enrolments.Any())
        {
            <div class="table-responsive">
                <table class="table table-striped align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Course</th>
                            <th>Branch</th>
                            <th>Enrolment Date</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var enrolment in Model.Enrolments)
                        {
                            <tr>
                                <td>
                                    <strong>@enrolment.Course?.Name</strong>

                                    @if (enrolment.Course?.Modules?.Any() == true)
                                    {
                                        <ul class="mb-0 small text-muted">
                                            @foreach (var module in enrolment.Course.Modules)
                                            {
                                                <li>@module.Name</li>
                                            }
                                        </ul>
                                    }
                                </td>
                                <td>@enrolment.Course?.Branch?.Name</td>
                                <td>@enrolment.EnrolDate.ToString("dd/MM/yyyy")</td>
                                <td>
                                    @if (enrolment.Status == "Active")
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">@enrolment.Status</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="alert alert-info mb-0">
                You do not currently have any enrolments.
            </div>
        }
    </div>
</div>