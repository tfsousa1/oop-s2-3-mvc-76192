@{
    ViewData["Title"] = "Student Dashboard";
}

<section class="agc-hero agc-hero-small">
    <div class="container">
        <span class="agc-eyebrow">Student Area</span>
        <h1 class="agc-title">Student Dashboard</h1>
        <p class="agc-subtitle">
            View your academic information through secure role-based access.
        </p>
    </div>
</section>

<section class="agc-section">
    <div class="container">
        <div class="row g-4">
            <div class="col-md-4">
                <div class="agc-card h-100">
                    <h5>My Profile</h5>
                    <p>Access your personal academic profile and linked records.</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="agc-card h-100">
                    <h5>My Enrolments</h5>
                    <p>View your current course enrolments and programme information.</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="agc-card h-100">
                    <h5>My Results</h5>
                    <p>Check attendance, coursework and released assessment results.</p>
                </div>
            </div>
        </div>
    </div>
</section>