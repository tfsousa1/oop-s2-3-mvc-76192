@{
    ViewData["Title"] = "Faculty Dashboard";
}

<section class="agc-hero agc-hero-small">
    <div class="container">
        <span class="agc-eyebrow">Faculty Area</span>
        <h1 class="agc-title">Faculty Dashboard</h1>
        <p class="agc-subtitle">
            Access teaching-related academic records and student information for assigned courses.
        </p>
    </div>
</section>

<section class="agc-section">
    <div class="container">
        <div class="row g-4">
            <div class="col-md-4">
                <div class="agc-card h-100">
                    <h5>My Courses</h5>
                    <p>View assigned courses and course structure information.</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="agc-card h-100">
                    <h5>My Students</h5>
                    <p>Access students linked to your teaching responsibilities.</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="agc-card h-100">
                    <h5>Assessments</h5>
                    <p>Manage attendance, coursework and exam-related academic data.</p>
                </div>
            </div>
        </div>
    </div>
</section>