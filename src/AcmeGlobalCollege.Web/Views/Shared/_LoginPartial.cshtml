@using Microsoft.AspNetCore.Identity
@using AcmeGlobalCollege.Web.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<div class="d-flex align-items-center agc-auth-area">
    @if (SignInManager.IsSignedIn(User))
    {
        <span class="agc-user-label me-3">
            @User.Identity?.Name
        </span>

        <form asp-area="Identity"
              asp-page="/Account/Logout"
              asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })"
              class="mb-0">
            <button type="submit" class="btn agc-logout-btn">Logout</button>
        </form>
    }
    else
    {
        <a class="btn agc-login-btn" asp-area="Identity" asp-page="/Account/Login">Login</a>
    }
</div>