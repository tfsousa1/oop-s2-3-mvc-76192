@model IEnumerable<AcmeGlobalCollege.Web.Models.CourseEnrolment>

@{
    ViewData["Title"] = "Enrolments";
}

<div class="mb-4">
    <div class="text-muted small">Administrator Area</div>
    <h1 class="display-5 fw-bold">Enrolments</h1>
    <p class="lead mb-0">View all student enrolments across courses and branches.</p>
</div>

<div class="mb-4">
    <a asp-action="Create" class="btn btn-primary">Create Enrolment</a>
</div>

<div class="card shadow-sm">
    <div class="card-header">
        <h2 class="h5 mb-0">Enrolment List</h2>
    </div>
    <div class="card-body">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-striped align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Student</th>
                            <th>Student Number</th>
                            <th>Course</th>
                            <th>Branch</th>
                            <th>Enrolment Date</th>
                            <th>Status</th>
                            <th class="text-end">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var e in Model)
                    {
                        <tr>
                            <td>@e.StudentProfile?.FullName</td>
                            <td>@e.StudentProfile?.StudentNumber</td>
                            <td>@e.Course?.Name</td>
                            <td>@e.Course?.Branch?.Name</td>
                            <td>@e.EnrolDate.ToString("dd/MM/yyyy")</td>
                            <td>@e.Status</td>
                            <td class="text-end">
                                <a asp-action="Details"
                                   asp-route-id="@e.Id"
                                   class="btn btn-sm btn-outline-primary">
                                    View
                                </a>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="alert alert-info mb-0">
                No enrolments found.
            </div>
        }
    </div>
</div>
