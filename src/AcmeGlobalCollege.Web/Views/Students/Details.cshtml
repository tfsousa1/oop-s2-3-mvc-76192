@model AcmeGlobalCollege.Web.ViewModels.StudentDetailsViewModel

@{
    ViewData["Title"] = "Student Details";
}

<section class="agc-hero agc-hero-small">
    <div class="container">
        <span class="agc-eyebrow">Administrator Area</span>
        <h1 class="agc-title">@Model.Student.FullName</h1>
        <p class="agc-subtitle">
            Student profile, contact details and linked enrolment information.
        </p>
    </div>
</section>

<section class="agc-section">
    <div class="container">
        <div class="row g-4">
            <div class="col-lg-5">
                <div class="agc-card h-100">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h4 class="mb-0">Student Profile</h4>
                        <a asp-controller="Students" asp-action="Index" class="btn btn-sm agc-btn-outline">Back to Students</a>
                    </div>

                    <dl class="row mb-0">
                        <dt class="col-sm-5">Student Number</dt>
                        <dd class="col-sm-7">@Model.Student.StudentNumber</dd>

                        <dt class="col-sm-5">Full Name</dt>
                        <dd class="col-sm-7">@Model.Student.FullName</dd>

                        <dt class="col-sm-5">Email</dt>
                        <dd class="col-sm-7">@Model.Student.Email</dd>

                        <dt class="col-sm-5">Phone</dt>
                        <dd class="col-sm-7">@Model.Student.Phone</dd>

                        <dt class="col-sm-5">Address</dt>
                        <dd class="col-sm-7">@Model.Student.Address</dd>

                        <dt class="col-sm-5">Date of Birth</dt>
                        <dd class="col-sm-7">@Model.Student.DateOfBirth.ToString("dd/MM/yyyy")</dd>
                    </dl>
                </div>
            </div>

            <div class="col-lg-7">
                <div class="agc-card h-100">
                    <h4 class="mb-3">Course Enrolments</h4>

                    @if (Model.Enrolments.Any())
                    {
                        <div class="table-responsive">
                            <table class="table agc-table">
                                <thead>
                                    <tr>
                                        <th>Course</th>
                                        <th>Branch</th>
                                        <th>Enrolment Date</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var enrolment in Model.Enrolments)
                                    {
                                        <tr>
                                            <td>@enrolment.Course?.Name</td>
                                            <td>@enrolment.Course?.Branch?.Name</td>
                                            <td>@enrolment.EnrolDate.ToString("dd/MM/yyyy")</td>
                                            <td>@enrolment.Status</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted mb-0">This student does not currently have any enrolments.</p>
                    }
                </div>
            </div>
        </div>
    </div>
</section>