@model AcmeGlobalCollege.Web.ViewModels.StudentDetailsViewModel

@{
    ViewData["Title"] = "Student Details";
}

<div class="mb-4">
    <div class="text-muted small">Administrator Area</div>
    <h1 class="display-5 fw-bold">Student Details</h1>
    <p class="lead mb-0">Student profile, contact details and linked enrolment information.</p>
</div>

<div class="mb-4">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Back to Students</a>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-header">
        <h2 class="h5 mb-0">Student Profile</h2>
    </div>
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Student Number</dt>
            <dd class="col-sm-9">@Model.Student.StudentNumber</dd>

            <dt class="col-sm-3">Full Name</dt>
            <dd class="col-sm-9">@Model.Student.FullName</dd>

            <dt class="col-sm-3">Email</dt>
            <dd class="col-sm-9">@Model.Student.Email</dd>

            <dt class="col-sm-3">Phone</dt>
            <dd class="col-sm-9">@Model.Student.Phone</dd>

            <dt class="col-sm-3">Address</dt>
            <dd class="col-sm-9">@Model.Student.Address</dd>

            <dt class="col-sm-3">Date of Birth</dt>
            <dd class="col-sm-9">@Model.Student.DateOfBirth.ToString("dd/MM/yyyy")</dd>
        </dl>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h2 class="h5 mb-0">Course Enrolments</h2>
        <a asp-controller="Enrolments" asp-action="Create" class="btn btn-sm btn-primary">Add Enrolment</a>
    </div>
    <div class="card-body">
        @if (Model.Enrolments.Any())
        {
            <div class="table-responsive">
                <table class="table table-striped align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Course</th>
                            <th>Branch</th>
                            <th>Enrolment Date</th>
                            <th>Status</th>
                            <th class="text-end">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var enrolment in Model.Enrolments)
                    {
                        <tr>
                            <td>@enrolment.Course?.Name</td>
                            <td>@enrolment.Course?.Branch?.Name</td>
                            <td>@enrolment.EnrolDate.ToString("dd/MM/yyyy")</td>
                            <td>@enrolment.Status</td>
                            <td class="text-end">
                                <a asp-controller="Enrolments"
                                   asp-action="Details"
                                   asp-route-id="@enrolment.Id"
                                   class="btn btn-sm btn-outline-primary">
                                    View
                                </a>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="alert alert-info mb-0">
                This student does not currently have any enrolments.
            </div>
        }
    </div>
</div>
