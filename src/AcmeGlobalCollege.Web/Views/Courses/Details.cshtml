@model AcmeGlobalCollege.Web.ViewModels.CourseDetailsViewModel

@{
    ViewData["Title"] = "Course Details";
}

<div class="mb-4">
    <div class="text-muted small">Administrator Area</div>
    <h1 class="display-5 fw-bold">Course Details</h1>
    <p class="lead mb-0">Course information, linked modules and enrolled students.</p>
</div>

<div class="mb-4 d-flex gap-2">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Back to Courses</a>
    <a asp-controller="Enrolments" asp-action="Create" class="btn btn-primary btn-sm">Add Enrolment</a>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-header">
        <h2 class="h5 mb-0">Course Summary</h2>
    </div>
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Course</dt>
            <dd class="col-sm-9">@Model.Course.Name</dd>

            <dt class="col-sm-3">Branch</dt>
            <dd class="col-sm-9">@Model.Course.Branch?.Name</dd>

            <dt class="col-sm-3">Start Date</dt>
            <dd class="col-sm-9">@Model.Course.StartDate.ToString("dd/MM/yyyy")</dd>

            <dt class="col-sm-3">End Date</dt>
            <dd class="col-sm-9">@Model.Course.EndDate.ToString("dd/MM/yyyy")</dd>
        </dl>
    </div>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-header">
        <h2 class="h5 mb-0">Modules</h2>
    </div>
    <div class="card-body">
        @if (Model.Modules.Any())
        {
            <div class="table-responsive">
                <table class="table table-striped align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Module Name</th>
                            <th>Description</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var module in Model.Modules)
                    {
                        <tr>
                            <td>@module.Name</td>
                            <td>@module.Description</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="alert alert-info mb-0">
                No modules are currently linked to this course.
            </div>
        }
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-header">
        <h2 class="h5 mb-0">Enrolled Students</h2>
    </div>
    <div class="card-body">
        @if (Model.Enrolments.Any())
        {
            <div class="table-responsive">
                <table class="table table-striped align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Student</th>
                            <th>Student Number</th>
                            <th>Email</th>
                            <th>Enrolment Date</th>
                            <th>Status</th>
                            <th class="text-end">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var enrolment in Model.Enrolments)
                    {
                        <tr>
                            <td>@enrolment.StudentProfile?.FullName</td>
                            <td>@enrolment.StudentProfile?.StudentNumber</td>
                            <td>@enrolment.StudentProfile?.Email</td>
                            <td>@enrolment.EnrolDate.ToString("dd/MM/yyyy")</td>
                            <td>@enrolment.Status</td>
                            <td class="text-end">
                                <a asp-controller="Students"
                                   asp-action="Details"
                                   asp-route-id="@enrolment.StudentProfileId"
                                   class="btn btn-sm btn-outline-primary">
                                    View Student
                                </a>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="alert alert-info mb-0">
                No students are currently enrolled in this course.
            </div>
        }
    </div>
</div>