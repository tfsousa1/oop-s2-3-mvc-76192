@model IEnumerable<AcmeGlobalCollege.Web.Models.Course>

@{
    ViewData["Title"] = "Courses";
}

<section class="agc-hero agc-hero-small">
    <div class="container">
        <span class="agc-eyebrow">Administrator Area</span>
        <h1 class="agc-title">Courses</h1>
        <p class="agc-subtitle">
            View academic programmes and their branch allocation across the institution.
        </p>
    </div>
</section>

<section class="agc-section">
    <div class="container">
        <div class="agc-card">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h4 class="mb-0">Course List</h4>
            </div>

            @if (Model.Any())
            {
                <div class="table-responsive">
                    <table class="table agc-table">
                        <thead>
                            <tr>
                                <th>Course</th>
                                <th>Branch</th>
                                <th>Start Date</th>
                                <th>End Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var course in Model)
                            {
                                <tr>
                                    <td>@course.Name</td>
                                    <td>@course.Branch?.Name</td>
                                    <td>@course.StartDate.ToString("dd/MM/yyyy")</td>
                                    <td>@course.EndDate.ToString("dd/MM/yyyy")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-muted mb-0">No courses found.</p>
            }
        </div>
    </div>
</section>