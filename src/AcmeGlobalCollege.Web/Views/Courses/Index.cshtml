@model IEnumerable<AcmeGlobalCollege.Web.Models.Course>

@{
    ViewData["Title"] = "Courses";
}

<div class="mb-4">
    <div class="text-muted small">Administrator Area</div>
    <h1 class="display-5 fw-bold">Courses</h1>
    <p class="lead mb-0">View academic programmes across all branches.</p>
</div>

<div class="card shadow-sm">
    <div class="card-header">
        <h2 class="h5 mb-0">Course List</h2>
    </div>
    <div class="card-body">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-striped align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Course</th>
                            <th>Branch</th>
                            <th>Start Date</th>
                            <th>End Date</th>
                            <th class="text-end">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var course in Model)
                        {
                            <tr>
                                <td>@course.Name</td>
                                <td>@course.Branch?.Name</td>
                                <td>@course.StartDate.ToString("dd/MM/yyyy")</td>
                                <td>@course.EndDate.ToString("dd/MM/yyyy")</td>
                                <td class="text-end">
                                    <a asp-action="Details"
                                       asp-route-id="@course.Id"
                                       class="btn btn-sm btn-outline-primary">
                                        View
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="alert alert-info mb-0">
                No courses found.
            </div>
        }
    </div>
</div>