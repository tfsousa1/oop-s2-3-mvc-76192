@{
    ViewData["Title"] = "Home";
}

<div class="text-center mt-5">
    <h1 class="display-5 fw-bold">Acme Global College</h1>
    <p class="lead mt-3">
        Multi-Branch Student & Course Management System
    </p>
    <p class="text-muted">
        A secure academic platform for managing student records, course structures, attendance and assessment information across multiple branches in Ireland.
    </p>
</div>

<div class="row mt-5 g-4">
    <div class="col-md-4">
        <div class="card shadow-sm h-100 p-3">
            <h5>Administrators</h5>
            <p>
                Manage branches, courses, modules, enrolments, staff assignments and result release settings.
            </p>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm h-100 p-3">
            <h5>Faculty</h5>
            <p>
                Access course-related student information, attendance and academic results based on assigned teaching responsibilities.
            </p>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm h-100 p-3">
            <h5>Students</h5>
            <p>
                View personal academic records, enrolments, attendance and released assessment results through secure login.
            </p>
        </div>
    </div>
</div>

<div class="row mt-4">
    <div class="col-12">
        <div class="card border-0 shadow-sm p-4">
            <h5 class="mb-3">Secure Access</h5>
            <p class="mb-0">
                Access to information is controlled by authentication and role-based authorization. Users only see the data relevant to their own role and permissions.
            </p>
        </div>
    </div>
</div>