@model IEnumerable<AcmeGlobalCollege.Web.Models.Branch>

@{
    ViewData["Title"] = "Branches";
}

<section class="agc-hero agc-hero-small">
    <div class="container">
        <span class="agc-eyebrow">Administrator Area</span>
        <h1 class="agc-title">Branches</h1>
        <p class="agc-subtitle">
            View institutional branch locations across the college structure.
        </p>
    </div>
</section>

<section class="agc-section">
    <div class="container">
        <div class="agc-card">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h4 class="mb-0">Branch List</h4>
            </div>

            @if (Model.Any())
            {
                <div class="table-responsive">
                    <table class="table agc-table">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Address</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var branch in Model)
                            {
                                <tr>
                                    <td>@branch.Name</td>
                                    <td>@branch.Address</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-muted mb-0">No branches found.</p>
            }
        </div>
    </div>
</section>